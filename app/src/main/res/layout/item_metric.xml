<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="@color/glass_fill"
    app:cardCornerRadius="18dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/glass_stroke"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="84dp"
        android:orientation="vertical"
        android:padding="12dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/ivMetricIcon"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:contentDescription="@null"
                app:tint="@color/on_sky_secondary" />

            <TextView
                android:id="@+id/tvMetricLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:letterSpacing="0.02"
                android:textColor="@color/on_sky_secondary"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Single line + autosize so a long value (e.g. "Waxing gibbous") shrinks to
             fit instead of wrapping to two lines and making this cell taller than its
             rowmate. Keeps the 2-col metric cards equal-height. -->
        <TextView
            android:id="@+id/tvMetricValue"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:maxLines="1"
            android:textColor="@color/on_sky"
            android:textSize="22sp"
            android:textStyle="bold"
            app:autoSizeTextType="uniform"
            app:autoSizeMinTextSize="13sp"
            app:autoSizeMaxTextSize="22sp"
            app:autoSizeStepGranularity="1sp" />

        <TextView
            android:id="@+id/tvMetricSub"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="@color/on_sky_secondary"
            android:textSize="11sp"
            android:visibility="gone" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
