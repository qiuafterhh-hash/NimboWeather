<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Scene background; per-widget alpha via WidgetAppearance.bgOpacity (setImageAlpha). -->
    <ImageView
        android:id="@+id/widgetBg"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitXY"
        android:src="@drawable/widget_bg_clear_day"
        android:contentDescription="@null" />

    <LinearLayout
        android:id="@+id/widgetRoot"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Top row: city + refresh -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/wCity"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:maxLines="1"
                android:ellipsize="end"
                android:textColor="#FFFFFF"
                android:textSize="16sp" />

            <ImageView
                android:id="@+id/wRefresh"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:alpha="0.8"
                android:src="@drawable/ic_refresh"
                android:contentDescription="@null" />
        </LinearLayout>

        <!-- Hero row: glyph + temp -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/wGlyph"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:layout_marginEnd="10dp"
                android:src="@drawable/ic_wx_sun"
                android:contentDescription="@null" />

            <TextView
                android:id="@+id/wTemp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="52sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/wCond"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxLines="1"
            android:ellipsize="end"
            android:textColor="#FFFFFF"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/wHiLo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="#E6FFFFFF"
            android:textSize="13sp" />

        <!-- AQI chip -->
        <TextView
            android:id="@+id/wAqi"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/widget_chip_bg"
            android:paddingLeft="10dp"
            android:paddingTop="4dp"
            android:paddingRight="10dp"
            android:paddingBottom="4dp"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:visibility="gone" />

        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- 3-hour forecast strip -->
        <LinearLayout
            android:id="@+id/wStrip"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="6dp"
            android:orientation="horizontal">

            <LinearLayout
                android:id="@+id/wSlot0"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">
                <TextView android:id="@+id/wSlot0Time" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:textColor="#CCFFFFFF" android:textSize="11sp" />
                <ImageView android:id="@+id/wSlot0Glyph" android:layout_width="22dp"
                    android:layout_height="22dp" android:layout_marginTop="2dp"
                    android:layout_marginBottom="2dp"
                    android:src="@drawable/ic_wx_sun" android:contentDescription="@null" />
                <TextView android:id="@+id/wSlot0Temp" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:textColor="#FFFFFF"
                    android:textSize="13sp" android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/wSlot1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">
                <TextView android:id="@+id/wSlot1Time" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:textColor="#CCFFFFFF" android:textSize="11sp" />
                <ImageView android:id="@+id/wSlot1Glyph" android:layout_width="22dp"
                    android:layout_height="22dp" android:layout_marginTop="2dp"
                    android:layout_marginBottom="2dp"
                    android:src="@drawable/ic_wx_sun" android:contentDescription="@null" />
                <TextView android:id="@+id/wSlot1Temp" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:textColor="#FFFFFF"
                    android:textSize="13sp" android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/wSlot2"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">
                <TextView android:id="@+id/wSlot2Time" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:textColor="#CCFFFFFF" android:textSize="11sp" />
                <ImageView android:id="@+id/wSlot2Glyph" android:layout_width="22dp"
                    android:layout_height="22dp" android:layout_marginTop="2dp"
                    android:layout_marginBottom="2dp"
                    android:src="@drawable/ic_wx_sun" android:contentDescription="@null" />
                <TextView android:id="@+id/wSlot2Temp" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:textColor="#FFFFFF"
                    android:textSize="13sp" android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/wUpdated"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#99FFFFFF"
            android:textSize="10sp" />
    </LinearLayout>
</FrameLayout>
